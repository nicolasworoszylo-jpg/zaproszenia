#!/usr/bin/env bash
# Repo Guardian — post-merge
# Runs after a successful `git pull` or `git merge`. Use it to:
#   1. Log activity (cross-laptop audit)
#   2. Surface drift: pokaż co przyszło z drugiego laptopa
#   3. macOS notify so Nicolas widzi "twój drugi komputer zrobił X"

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
. "${HOOK_DIR}/_lib.sh"

# Last commit summary (post-merge → HEAD is now the new tip)
LAST=$(git log -1 --pretty=format:'%h %an: %s' 2>/dev/null || echo "unknown")
BRANCH=$(guardian_current_branch)

# How many commits arrived in this merge?
RANGE_COMMITS=$(git log --pretty=oneline ORIG_HEAD..HEAD 2>/dev/null | wc -l | tr -d ' ')
[ -z "$RANGE_COMMITS" ] && RANGE_COMMITS=0

guardian_ok "post-merge: $RANGE_COMMITS new commit(s) on '$BRANCH' — HEAD: $LAST"
guardian_log_activity "post-merge" "incoming=$RANGE_COMMITS head=$LAST"

if [ "$RANGE_COMMITS" -gt 0 ]; then
  guardian_notify_mac "Repo Guardian: zaproszenia" "$RANGE_COMMITS nowych commitów na $BRANCH"
fi

# Quick reminder if package.json or supabase/ migrations changed
CHANGED=$(git diff --name-only ORIG_HEAD HEAD 2>/dev/null)
if echo "$CHANGED" | grep -q 'package.json\|package-lock\|supabase/migrations/'; then
  guardian_warn "Uwaga: zmiany w deps lub migracjach Supabase. Rozważ 'npm run setup' / migrację."
fi

exit 0
