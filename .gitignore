.vercel
*.jsx.tmp

# Local IDE / tools
.claude/

# Repo Guardian state — keep folder, ignore contents (own .gitignore inside)
.guardian/

# Env files — must never enter the repo
.env
.env.*
*.env
*.env.local
*.env.production
# Exception: .env.example is a template with placeholders, safe to commit
!.env.example

# Common junk
.DS_Store
node_modules/
npm-debug.log*
.idea/
.vscode/

# Build artifacts
dist/
build/

# Photo pipeline — client photos and mail correspondence NEVER enter git
# (only photos/README.md does)
photos/inbox/
photos/processed/
photos/reports/
photos/drafts/
photos/sent/
