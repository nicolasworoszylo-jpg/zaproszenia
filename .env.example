# Photo pipeline — sekretne klucze do robota scripts/photos-{scan,send}.mjs
# Skopiuj ten plik do `.env` i wypełnij prawdziwymi wartościami.
# `.env` jest w .gitignore — nigdy nie commituj prawdziwych kluczy.

# ───── Resend (wysyłka maili z kontakt@zaproszeniaonline.com) ─────
# Skąd: https://resend.com/api-keys (zapytaj Nicolasa o klucz, lub utwórz
# nowy specjalnie dla robota z restricted permission "Sending access").
# Format: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=

# Adres "From" w nagłówku maila — musi być na zweryfikowanej domenie w Resend.
# DNS dla zaproszeniaonline.com już zweryfikowane (DKIM/SPF/DMARC OK).
RESEND_FROM=kontakt@zaproszeniaonline.com

# Adres do BCC (kopia każdego wysłanego maila trafia tutaj — Twoja skrzynka)
# i jednocześnie Reply-To (odpowiedzi klientów wpadają tam).
RESEND_REPLY_TO=kontakt@zaproszeniaonline.com

# ───── Supabase (pobieranie adresu klienta po ORDER_ID) ─────
# Skąd: Supabase Studio → Project Settings → API → "Project URL" + "service_role"
# Service role bypassuje RLS — używamy lokalnie, NIGDY nie wystawiaj w klient JS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
